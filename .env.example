# SearchSpace / SearchAgora — store location discovery
SEARCHSPACE_API_KEY=
SEARCHSPACE_API_URL=https://zues.searchagora.com/api/v1

# Geoapify — store place details and contact discovery
GEOAPIFY_API_KEY=

# Agora — voice agent (App ID required; add customer id/secret for live PSTN)
AGORA_APP_ID=
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=
AGORA_FROM_NUMBER=

# Optional fallbacks
GEMINI_API_KEY=
GOOGLE_PLACES_API_KEY=

PUBLIC_URL=http://localhost:4000
PORT=4000
